      <aliases enabled='yes' />
      <column caption='Total Loan Applications' datatype='integer' name='[Calculation_1634243782318100481]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id])' />
      </column>
      <column caption='MTD Total Loan Applications' datatype='integer' name='[Calculation_1634243782326022146]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;DATEDIFF(&apos;month&apos;,[issue_date],{MAX([issue_date])}) = 0&#13;&#10;THEN&#13;&#10;[id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='MoM Loan Applications' datatype='real' name='[Calculation_1634243782328692740]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1634243782326022146] - [MTD Loan Application (copy)_1634243782327578627])&#13;&#10;/&#13;&#10;[MTD Loan Application (copy)_1634243782327578627]' />
      </column>
      <column caption='Total Funded Amount' datatype='integer' name='[Calculation_1634243782352392198]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([loan_amount])' />
      </column>
      <column caption='MoM Funded Amount' datatype='real' name='[Calculation_1634243782354833417]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Total Loan Applications (copy)_1634243782353182727] - [MTD Total Funded Amount (copy)_1634243782354231304])&#13;&#10;/&#13;&#10;[MTD Total Funded Amount (copy)_1634243782354231304]' />
      </column>
      <column caption='Total Amount Recieved' datatype='integer' name='[Calculation_1634243782357717003]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_payment])' />
      </column>
      <column caption='MoM Amount Recieved' datatype='real' name='[Calculation_1634243782360895506]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Total Funded Amount (copy)_1634243782358618125] - [MTD Total Amount Recieved (copy)_1634243782360449041])&#13;&#10;/&#13;&#10;[MTD Total Amount Recieved (copy)_1634243782360449041]' />
      </column>
      <column caption='Avg Int Rate' datatype='real' name='[Calculation_1634243782362628115]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([int_rate])' />
      </column>
      <column caption='MoM Avg Int Rate' datatype='real' name='[Calculation_1634243782365048854]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Total Amount Recieved (copy)_1634243782364094484] - [MTD Avg Int Rate (copy)_1634243782364782613])&#13;&#10;/&#13;&#10;[MTD Avg Int Rate (copy)_1634243782364782613]' />
      </column>
      <column caption='Avg DTI' datatype='real' name='[Calculation_1634243782366400535]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([dti])' />
      </column>
      <column caption='MoM Avg DTI' datatype='real' name='[Calculation_1634243782367412250]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([MTD Avg Int Rate (copy)_1634243782366810136] - [MTD Avg DTI (copy)_1634243782367268889])&#13;&#10;/&#13;&#10;[MTD Avg DTI (copy)_1634243782367268889]' />
      </column>
      <column caption='Good Loan % ' datatype='real' name='[Calculation_1634243782537699359]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(if[Good vs Bad Loan] = &apos;Good Loan&apos;THEN[id] END)&#13;&#10;/&#13;&#10;COUNT([id])' />
      </column>
      <column caption='Good Loan Application' datatype='integer' name='[Calculation_1634243782540517408]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Good vs Bad Loan] = &apos;Good Loan&apos; THEN[id] END)' />
      </column>
      <column caption='Dynamic Measure' datatype='integer' name='[Calculation_1634243782677061672]' role='measure' type='quantitative'>
